# Web
PORT=3000

# Database
DATABASE_PATH=./data/app.sqlite

# BSC collector
BSC_RPC_URL=https://public-bsc.nownodes.io/
COLLECTOR_LOOKBACK_BLOCKS=200
COLLECTOR_BATCH_BLOCKS=50

# OpeniLink Hub
OPENILINK_HUB_URL=https://hub.openilink.com
OPENILINK_ADMIN_URL=https://admin.openilink.com
OPENILINK_OAUTH_CALLBACK_URL=https://yourdomain.com/auth/callback

# Payment watcher
PAYMENT_WATCHER_ENABLED=false
PAYMENT_CONFIRMATIONS=3
