{
  "apps": [
    {
      "name": "regouapp-web",
      "namespace": "regouapp",
      "cwd": "/root/regou-app",
      "script": "src/server/index.ts",
      "interpreter": "/root/.bun/bin/bun",
      "interpreterArgs": "",
      "env": {
        "PORT": 30082,
        "OPENILINK_HUB_URL": "https://hub.openilink.com",
        "OPENILINK_ADMIN_URL": "https://admin.openilink.com",
        "OPENILINK_OAUTH_CALLBACK_URL": "https://regou.app/auth/callback",
        "BSC_RPC_URL": "https://public-bsc.nownodes.io/",
        "DATABASE_PATH": "./data/app.sqlite"
      },
      "autorestart": true,
      "watch": false,
      "merge_logs": true,
      "time": true,
      "out_file": "logs/regouapp-web.out.log",
      "error_file": "logs/regouapp-web.err.log"
    },
    {
      "name": "regouapp-collector",
      "namespace": "regouapp",
      "cwd": "/root/regou-app",
      "script": "src/collectors/run.ts",
      "interpreter": "/root/.bun/bin/bun",
      "interpreterArgs": "run",
      "env": {
        "BSC_RPC_URL": "https://public-bsc.nownodes.io/",
        "DATABASE_PATH": "./data/app.sqlite"
      },
      "autorestart": true,
      "watch": false,
      "merge_logs": true,
      "time": true,
      "out_file": "logs/regouapp-collector.out.log",
      "error_file": "logs/regouapp-collector.err.log"
    },
    {
      "name": "regouapp-worker",
      "namespace": "regouapp",
      "cwd": "/root/regou-app",
      "script": "src/workers/run.ts",
      "interpreter": "/root/.bun/bin/bun",
      "interpreterArgs": "run",
      "env": {
        "OPENILINK_HUB_URL": "https://hub.openilink.com",
        "DATABASE_PATH": "./data/app.sqlite"
      },
      "autorestart": true,
      "watch": false,
      "merge_logs": true,
      "time": true,
      "out_file": "logs/regouapp-worker.out.log",
      "error_file": "logs/regouapp-worker.err.log"
    }
  ]
}
