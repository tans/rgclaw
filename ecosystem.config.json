{
  "apps": [
    {
      "name": "rgclaw-web",
      "namespace": "rgclaw",
      "cwd": ".",
      "script": "src/server/index.ts",
      "interpreter": "bun",
      "interpreterArgs": "run",
      "env": {
        "PORT": 3002,
        "OPENILINK_HUB_URL": "https://hub.openilink.com",
        "OPENILINK_ADMIN_URL": "https://admin.openilink.com",
        "OPENILINK_OAUTH_CALLBACK_URL": "https://rgclaw.ali.minapp.xin/auth/callback",
        "BSC_RPC_URL": "https://public-bsc.nownodes.io/",
        "DATABASE_PATH": "./data/app.sqlite"
      },
      "autorestart": true,
      "watch": false,
      "merge_logs": true,
      "time": true,
      "out_file": "logs/rgclaw-web.out.log",
      "error_file": "logs/rgclaw-web.err.log"
    },
    {
      "name": "rgclaw-collector",
      "namespace": "rgclaw",
      "cwd": ".",
      "script": "src/collectors/run.ts",
      "interpreter": "bun",
      "interpreterArgs": "run",
      "env": {
        "BSC_RPC_URL": "https://public-bsc.nownodes.io/",
        "DATABASE_PATH": "./data/app.sqlite"
      },
      "autorestart": true,
      "watch": false,
      "merge_logs": true,
      "time": true,
      "out_file": "logs/rgclaw-collector.out.log",
      "error_file": "logs/rgclaw-collector.err.log"
    },
    {
      "name": "rgclaw-worker",
      "namespace": "rgclaw",
      "cwd": ".",
      "script": "src/workers/run.ts",
      "interpreter": "bun",
      "interpreterArgs": "run",
      "env": {
        "OPENILINK_HUB_URL": "https://hub.openilink.com",
        "DATABASE_PATH": "./data/app.sqlite"
      },
      "autorestart": true,
      "watch": false,
      "merge_logs": true,
      "time": true,
      "out_file": "logs/rgclaw-worker.out.log",
      "error_file": "logs/rgclaw-worker.err.log"
    }
  ]
}
